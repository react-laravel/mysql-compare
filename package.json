{
  "name": "mysql-compare",
  "version": "0.1.0",
  "description": "Lightweight desktop MySQL client with SSH tunnel, browse/edit, schema diff & sync",
  "main": "out/main/index.js",
  "author": "you",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "npm run build && electron-vite preview",
    "preview": "electron-vite preview",
    "web:dev": "vite --config vite.web.config.ts",
    "web:build": "vite build --config vite.web.config.ts",
    "web:preview": "vite preview --config vite.web.config.ts",
    "web:server": "tsx src/web/index.ts",
    "web:start": "tsx src/web/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-store": "^11.0.2",
    "express": "^5.2.1",
    "monaco-editor": "^0.55.1",
    "mysql2": "3.11.5",
    "pg": "^8.13.1",
    "redis": "^4.7.1",
    "ssh2": "1.16.0",
    "uuid": "11.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "22.10.2",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "1.15.1",
    "@types/uuid": "10.0.0",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "10.4.20",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "electron": "^41.3.0",
    "electron-builder": "25.1.8",
    "electron-vite": "^4.0.1",
    "jsdom": "^26.1.0",
    "lucide-react": "0.468.0",
    "postcss": "8.4.49",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "2.5.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vitest": "^4.0.18",
    "zustand": "5.0.2"
  }
}
